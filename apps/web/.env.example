# ============================================
# GREETING CARD MAKER - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:  cp .env.example .env

# ============================================
# SUPABASE (Cloud - New Key Format)
# ============================================
# Go to: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Secret key (server-only) — Settings → API → Secret keys (starts with sb_secret_...)
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Go to: Settings → Database → Connection string (URI)
# Use "Session mode" for DATABASE_URL, "Direct" for DIRECT_URL
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ============================================
# REPLICATE (runs NANO BANANA model)
# ============================================
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your-replicate-api-token

# ============================================
# APP CONFIG
# ============================================
CORS_ORIGIN=http://localhost:3001
NODE_ENV=development
